<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="Guppy.UI.Views.MainWindow"
        Title="Guppy"
        Width="740" Height="780"
        Background="#2B2B2B">

    <Viewbox Margin="24">
        <!-- Column 0 holds the rank numbers, column 1 the board.
             Row 0 holds the board, row 1 the file letters. -->
        <Grid ColumnDefinitions="Auto,Auto" RowDefinitions="Auto,Auto">

            <UniformGrid x:Name="RankLabels" Grid.Row="0" Grid.Column="0"
                         Rows="8" Columns="1" Width="28" Height="640" />

            <UniformGrid x:Name="BoardGrid" Grid.Row="0" Grid.Column="1"
                         Rows="8" Columns="8" Width="640" Height="640" />

            <UniformGrid x:Name="FileLabels" Grid.Row="1" Grid.Column="1"
                         Rows="1" Columns="8" Width="640" Height="28" />

        </Grid>
    </Viewbox>

</Window>